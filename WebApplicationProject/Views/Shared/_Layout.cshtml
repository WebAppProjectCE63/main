@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
@using WebApplicationProject.Services
@inject NotificationService NotiService
@{
    var username = Context.Session.GetString("Username");
    var userId = Context.Session.GetInt32("UserId");
    var image = Context.Session.GetString("Userimage");
    int unreadCount = 0;
    if (userId.HasValue)
    {
        try { unreadCount = NotiService.GetUnreadCount(userId.Value); } catch { unreadCount = 0; }
    }
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplicationProject</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplicationProject.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <header>
        <nav id="navbar">

            <div id="weblogo">
                <img src="https://i.ibb.co/23sXzpHQ/Expedition-Express-Logo-Grad-Final.png" alt="Logo">
            </div>
            
            <button id="mobileMenuBtn">
                ☰
            </button>
            <div id="navContent">
                <div id="navitem">
                    <ul>
                        <li><a asp-controller="Home" asp-action="Home">Home</a></li>
                        <li><a asp-controller="Event" asp-action="MyEvent">My Event</a></li>
                        <li><a asp-controller="Event" asp-action="Create">Create Event</a></li>
                        @* <li><a asp-controller="Home" asp-action="Index">Index Debug</a></li> *@
                    </ul>
                </div>
            
            <div id="navprofile">

                <div id="profilename">

                    @if (!string.IsNullOrEmpty(username))
                    {
                        <a asp-controller="Profile" asp-action="profilepage" asp-route-id="@userId.Value">
                        <h4>@username</h4>

                        @* @if (userId.HasValue)
                        {
                            <p>ID: @userId.Value</p>
                        } *@
                        </a>

                        <a asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Signup" class="btn-nav btn-signup">Signup</a>
                        <a asp-controller="Account" asp-action="Login" class="btn-nav btn-login">Login</a>
                    }

                </div>
                @if (!string.IsNullOrEmpty(username))
                {
                    <a asp-controller="Profile" asp-action="profilepage" asp-route-id="@userId.Value">
                        <img src="@image" alt="Profile" />
                    </a>

                <div id="navnoti">
                    <a asp-controller="Notification" asp-action="Index" title="Notifications">
                        <span id="notiBell" style="position:relative; display:inline-block;">
                            🔔
                            <span id="notiBadge" style="position:absolute; top:-8px; right:-8px; background:#dc3545; color:white; border-radius:50%; padding:2px 6px; font-size:0.75rem; display:@(unreadCount>0?"inline-block":"none");">@unreadCount</span>
                        </span>
                    </a>
                </div>
                }
            </div>
            </div>
        </nav>
    </header>

    @if (TempData["ErrorMessage"] != null)
    {
        <div id="errorAlert" class="temp-alert error-alert">

            <span>@TempData["ErrorMessage"]</span>

            <button onclick="document.getElementById('errorAlert').style.display='none'">
                &times;
            </button>

        </div>

        <script>
                setTimeout(function () {
                    var alertElement = document.getElementById('errorAlert');
                    if (alertElement) {
                        alertElement.style.opacity = "0";
                        setTimeout(function () {
                            alertElement.style.display = 'none';
                        }, 500);
                    }
                }, 5000);
        </script>
    }


    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successAlert" class="temp-alert success-alert">

            <span>@TempData["SuccessMessage"]</span>

            <button onclick="document.getElementById('successAlert').style.display='none'">
                &times;
            </button>

        </div>

        <script>
                setTimeout(function () {
                    var alertElement = document.getElementById('successAlert');
                    if (alertElement) {
                        alertElement.style.opacity = "0";
                        setTimeout(function () {
                            alertElement.style.display = 'none';
                        }, 500);
                    }
                }, 5000);
        </script>
    }


    <main role="main">
        @RenderBody()
    </main>


    <footer class="my-footer">
        <div>
            &copy; 2569 - WebApplicationProject -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/noti_polling.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/realtime_update.js" asp-append-version="true"></script>
</body>
</html>