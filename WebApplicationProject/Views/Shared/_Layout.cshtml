@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
@{
    var username = Context.Session.GetString("Username");
    var userId = Context.Session.GetInt32("UserId");
    var image = Context.Session.GetString("Userimage");
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplicationProject</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplicationProject.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <header>
        <nav id="navbar">

            <div id="weblogo">
                <img src="https://i.ibb.co/5WhJMddb/Expedition-Express-Logo.png" alt="Logo">
            </div>
            
            <button id="mobileMenuBtn">
                ☰
            </button>
            <div id="navContent">
                <div id="navitem">
                    <ul>
                        <li><a asp-controller="Home" asp-action="Home">Home</a></li>
                        <li><a asp-controller="Event" asp-action="MyEvent">My Event</a></li>
                        <li><a asp-controller="Event" asp-action="Create">Create Event</a></li>
                        @* <li><a asp-controller="Home" asp-action="Index">Index Debug</a></li> *@
                    </ul>
                </div>
            
            <div id="navprofile">

                <div id="profilename">

                    @if (!string.IsNullOrEmpty(username))
                    {
                        <a asp-controller="Profile" asp-action="profilepage" asp-route-id="@userId.Value">
                        <h4>@username</h4>

                        @* @if (userId.HasValue)
                        {
                            <p>ID: @userId.Value</p>
                        } *@
                        </a>

                        <a asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Signup" class="btn-nav btn-signup">Signup</a>
                        <a asp-controller="Account" asp-action="Login" class="btn-nav btn-login">Login</a>
                    }

                </div>
                @if (!string.IsNullOrEmpty(username))
                {
                    <a asp-controller="Profile" asp-action="profilepage" asp-route-id="@userId.Value">
                        <img src="@image" alt="Profile" />
                    </a>
                }
            </div>
            </div>
        </nav>
    </header>

    @if (TempData["ErrorMessage"] != null)
    {
        <div id="errorAlert" class="temp-alert error-alert">

            <span>@TempData["ErrorMessage"]</span>

            <button onclick="document.getElementById('errorAlert').style.display='none'">
                &times;
            </button>

        </div>

        <script>
                setTimeout(function () {
                    var alertElement = document.getElementById('errorAlert');
                    if (alertElement) {
                        alertElement.style.opacity = "0";
                        setTimeout(function () {
                            alertElement.style.display = 'none';
                        }, 500);
                    }
                }, 5000);
        </script>
    }


    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successAlert" class="temp-alert success-alert">

            <span>@TempData["SuccessMessage"]</span>

            <button onclick="document.getElementById('successAlert').style.display='none'">
                &times;
            </button>

        </div>

        <script>
                setTimeout(function () {
                    var alertElement = document.getElementById('successAlert');
                    if (alertElement) {
                        alertElement.style.opacity = "0";
                        setTimeout(function () {
                            alertElement.style.display = 'none';
                        }, 500);
                    }
                }, 5000);
        </script>
    }


    <main role="main">
        @RenderBody()
    </main>


    <footer class="my-footer">
        <div>
            &copy; 2569 - WebApplicationProject -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        async function updateEventStatusRealtime() {
            const now = new Date();
            for (const card of document.querySelectorAll('.Event')) {
                const eventIdInput = card.querySelector('input[name="eventId"]');
                const eventId = eventIdInput ? eventIdInput.value : null;
                if (!eventId) continue;

                try {
                    // ดึงสถานะปัจจุบัน (ห้ามใช้ Cache เพื่อให้มัน Real-time จริงๆ)
                    const response = await fetch(`/Event/CheckStatus/${eventId}`, { cache: "no-store" });
                    if (!response.ok) continue;
                    const data = await response.json();

                    const eventStartTime = new Date(data.dateTime);
                    const closeTime = new Date(eventStartTime.getTime() - (2 * 60 * 1000));

                    const isActuallyLocked = data.isRegistrationClosed || (now >= closeTime);
                    const isOngoing = now >= eventStartTime;

                    // -------------------------------------------------------------
                    // 1. จัดการป้ายใต้รูปภาพ (แก้ปัญหาป้ายขึ้นซ้อนกันแบบเด็ดขาด)
                    // -------------------------------------------------------------
                    const imageColumn = card.querySelector('.image-column');
                    if (imageColumn) {
                        const allBadges = imageColumn.querySelectorAll('.status-badge');

                        // เช็คก่อนว่าเซิร์ฟเวอร์ส่งป้าย Ended (งานจบแล้ว) มาหรือเปล่า
                        const isEnded = Array.from(allBadges).some(b => b.textContent.trim() === "Ended");

                        // ลบป้ายสถานะเดิมทิ้งให้หมดเพื่อเคลียร์พื้นที่
                        allBadges.forEach(b => b.remove());

                        // สร้างป้ายใหม่ขึ้นมาแค่อันเดียว
                        const newBadge = document.createElement('span');
                        newBadge.className = 'status-badge';
                        newBadge.style.cssText = 'width: 100%; box-sizing: border-box; text-align: center; display: block; padding: 2px;';

                        if (isEnded) {
                            newBadge.classList.add('status-ended');
                            newBadge.textContent = 'Ended';
                        } else if (isOngoing) {
                            newBadge.classList.add('status-ongoing');
                            newBadge.textContent = 'Ongoing';
                        } else if (isActuallyLocked) {
                            newBadge.classList.add('statis-close');
                            newBadge.style.backgroundColor = '#dc3545';
                            newBadge.style.color = 'white';
                            newBadge.style.marginTop = '-4px';
                            newBadge.textContent = '🔒 Locked';
                        } else {
                            newBadge.classList.add('status-upcoming');
                            newBadge.textContent = 'Upcoming';
                        }

                        // แปะป้ายใหม่เข้าไปใต้รูปภาพ
                        const imgDiv = imageColumn.querySelector('.event-image');
                        if (imgDiv) imgDiv.after(newBadge);
                    }

                    // -------------------------------------------------------------
                    // 2. จัดการป้าย Waiting <-> Not Selected สำหรับตัวสำรอง
                    // -------------------------------------------------------------
                    const participantBadge = card.querySelector('.event-title .badge');
                    if (participantBadge && !participantBadge.classList.contains('badge-host')) {
                        if (isActuallyLocked && (participantBadge.textContent.trim() === "Waiting" || participantBadge.classList.contains('badge-waiting'))) {
                            participantBadge.textContent = "Not Selected";
                            participantBadge.className = "badge badge-closed";
                        } else if (!isActuallyLocked && (participantBadge.textContent.trim() === "Not Selected" || participantBadge.classList.contains('badge-closed'))) {
                            participantBadge.textContent = "Waiting";
                            participantBadge.className = "badge badge-waiting";
                        }
                    }

                    // -------------------------------------------------------------
                    // 3. จัดการปุ่ม (ซ่อน Manage/Edit -> สลับเป็น View Reviews)
                    // -------------------------------------------------------------
                    const isHost = card.querySelector('.badge-host') !== null;
                    const isHome = window.location.pathname.toLowerCase().includes('/home');

                    if (isHost && !isHome) {
                        const editBtns = card.querySelectorAll('a[href*="Edit"]');
                        const deleteForms = card.querySelectorAll('form[action*="Delete"]');
                        const manageBtns = card.querySelectorAll('a[href*="Manage"]');

                        if (isOngoing || Array.from(imageColumn?.querySelectorAll('.status-badge') || []).some(b => b.textContent.trim() === "Ended")) {
                            // ถ้างานเริ่มไปแล้ว -> ซ่อนปุ่มแก้ไข/ลบ/จัดการ ทั้งหมด
                            editBtns.forEach(btn => btn.style.display = 'none');
                            deleteForms.forEach(form => form.style.display = 'none');
                            manageBtns.forEach(btn => btn.style.display = 'none');

                            // สร้างปุ่ม View Reviews ขึ้นมาแทนที่โดยไม่ต้อง Refresh
                            const actionsContainers = card.querySelectorAll('.normal-actions, .extra-actions');
                            actionsContainers.forEach(container => {
                                if (!container.querySelector('.review-auto-btn') && !container.querySelector('button[onclick*="Review"]')) {
                                    const reviewBtn = document.createElement('button');
                                    reviewBtn.className = 'view-btn review-auto-btn';
                                    reviewBtn.type = 'button';
                                    reviewBtn.textContent = 'View Reviews';
                                    reviewBtn.onclick = () => window.location.href = `/Review/Review/${eventId}`;
                                    container.appendChild(reviewBtn);
                                }
                            });
                        } else if (isActuallyLocked) {
                            // ถ้าล็อกแล้วแต่ยังไม่เริ่มงาน -> ซ่อนแก้ไข/ลบ และเปลี่ยน Manage เป็น View Summary
                            editBtns.forEach(btn => btn.style.display = 'none');
                            deleteForms.forEach(form => form.style.display = 'none');
                            manageBtns.forEach(btn => {
                                btn.style.display = 'inline-block';
                                btn.textContent = 'View Summary';
                            });
                        } else {
                            // กลับเป็นปกติ
                            editBtns.forEach(btn => btn.style.display = 'inline-block');
                            deleteForms.forEach(form => form.style.display = 'inline-block');
                            manageBtns.forEach(btn => {
                                btn.style.display = 'inline-block';
                                btn.textContent = btn.classList.contains('btn-dark-link') && !btn.closest('.normal-actions') ? 'Manage Event' : 'Manage';
                            });
                        }
                    } else if (!isHost && !isHome) {
                        // ซ่อนปุ่ม Cancel Join สำหรับ User ทั่วไปเมื่อถูกล็อก
                        const cancelForm = card.querySelector('form[action*="CancelJoin"]');
                        if (cancelForm) cancelForm.style.display = isActuallyLocked ? 'none' : 'inline-block';
                    }
                } catch (e) {
                    console.error("Polling error:", e);
                }
            }
        }

        setInterval(updateEventStatusRealtime, 10000);
        updateEventStatusRealtime();
    </script>
</body>
</html>