@model WebApplicationProject.Models.ProfilePageViewModel

<link rel="stylesheet" href="~/css/profilestyle.css">
<div class="pagebanner">
    <h1>Profile</h1>
    <p>รายละเอียดข้อมูลส่วนบุคคล</p>
</div>

<div class="profilebanner">
    <div class="profileimg">
        <img src=@Model.UserInfo.Image alt="Profile" id="prevImg">
    </div>
    <div class="profileinfo">
        @if (Model.UserInfo.Settings.PrivateAccount && Model.CurrentLoggedInUserId != Model.UserInfo.Id)
        {
            <div class="moreinfo">
                <div class="gender">
                    <h1>
                        <span id="prevFname">@Model.UserInfo.FName</span>
                        <span id="prevSname">@Model.UserInfo.SName</span>
                    </h1>
                </div>
                <div class="age">
                    <h3>Gender</h3>
                    <p>@Model.UserInfo.Gender</p>
                </div>
            </div>
            <div class="private-content-mock">
                <div>🔒</div>
                <h2>บัญชีนี้เป็นบัญชีส่วนตัว</h2>
            </div>
        }
        else
        {
            <h1>
                <span id="prevFname">@Model.UserInfo.FName</span>
                <span id="prevSname">@Model.UserInfo.SName</span>
            </h1>
            @if (Model.UserInfo.Settings.ShowEmail)
            {
                <p id="prevEmail">Email: @Model.UserInfo.Email</p>
            }
            else
            {
                <p id="prevEmail">Email: Private</p>
            }
            <div class="moreinfo">
                <div class="long-info">
                    <h3>Rating</h3>
                    @{
                        double averageScore = Model.UserInfo.Reviewslist.Any() ? Model.UserInfo.Reviewslist.Average(r => r.stars) : 0;
                        int totalReviews = Model.UserInfo.Reviewslist.Count();
                        int roundScore = (int)Math.Round(averageScore, MidpointRounding.AwayFromZero);
                    }
                    @if (totalReviews == 0)
                    {
                        <p>ผู้ใช้ยังไม่ได้รับ Review ใดๆ</p>
                    }
                    else
                    {
                        <p class="stars">
                            @for (int i = 0; i < roundScore; i++)
                            {
                                <span>★</span>
                            }
                            @for (int i = roundScore; i < 5; i++)
                            {
                                <span>☆</span>
                            }
                            <span class="review-info" onclick="scorrInto('review-section')">
                                @averageScore.ToString("0.0") (@totalReviews รีวิว)
                            </span>
                        </p>
                    }
                </div>
            </div>
            <div class="moreinfo">
                <div class="gender">
                    <h3>Gender</h3>
                    <p>@Model.UserInfo.Gender</p>
                </div>
                <div class="age">
                    <h3>Age</h3>
                    @{
                        var today = DateTime.Today;
                        var age = today.Year - Model.UserInfo.Birthday.Year;
                        if (Model.UserInfo.Birthday.Date > today.AddYears(-age))
                        {
                            age--;
                        }
                    }
                    <p>@age</p>
                </div>
            </div>
            @if (Model.CurrentLoggedInUserId == Model.UserInfo.Id)

            {
                <button class="edit-btn" onclick="openEditModal()">Edit Profile</button>
            }
        }
    </div>
</div>

<div class="activitycolumn">
    <h2>Recent Host Activity</h2>
    <p>กิจกรรมที่เคยสร้าง</p>
    @if (((Model.CurrentLoggedInUserId == Model.UserInfo.Id ||
        (!Model.UserInfo.Settings.PrivateAccount && Model.UserInfo.Settings.ShowHostedEvents))
        && (Model.HostedEvents != null && Model.HostedEvents.Any())))

    {
        <div class="activitylist">
        @foreach ( var evModel in Model.HostedEvents)
        {
            var ev = evModel.EventData;
            <div class="activity">
                <div class="activityimg">
                    <img src=@ev.Image alt="Event">
                </div>
                <div class="activityinfo">
                    <h2>@ev.Title</h2>
                    <p>@ev.Description</p>
                    <div class="eventinfo">
                        <div class="taglist">
                            @if (ev.Tags != null && ev.Tags.Any())
                            {
                                @foreach (var tagName in ev.Tags)
                                {
                                    <span class="tag">#@tagName</span>
                                }
                            }
                            else
                            {
                                <span class="tag">ไม่มีแท็ก</span>
                            }
                        </div>
                        <div class="datetime">
                            @if (ev.DateTime.Date == ev.EndDateTime.Date)
                            {
                                <span class="time">@ev.DateTime.ToString("HH:mm ") - @ev.EndDateTime.ToString(" HH:mm")</span>
                                <span class="date">@ev.DateTime.ToString("dd")</span>
                                <span class="date">@ev.DateTime.ToString("MMM")</span>
                                <span class="date">@ev.DateTime.ToString("yyyy")</span>
                            }
                            else
                            {
                                    <span class="time">@ev.DateTime.ToString("HH:mm ")</span>
                                    <span class="date">@ev.DateTime.ToString("dd")</span>
                                    <span class="date">@ev.DateTime.ToString("MMM")</span>
                                    <span class="date">@ev.DateTime.ToString("yyyy")</span>
                                    <p> To </p>
                                    <span class="time">@ev.EndDateTime.ToString("HH:mm ")</span>
                                    <span class="date">@ev.EndDateTime.ToString("dd")</span>
                                    <span class="date">@ev.EndDateTime.ToString("MMM")</span>
                                    <span class="date">@ev.EndDateTime.ToString("yyyy")</span>
                            }
                        </div>
                    </div>
                    <div class="member-row">
                        <div class="avatars">
                        @foreach (var user in evModel.ParticipantAvatars)
                        {
                            <img src="@user.Image" alt="@user.FName" title="@user.FName @user.SName">
                        }
                        @if (ev.CurrentParticipants > 3)
                        {
                            <span class="more-users">+@(ev.CurrentParticipants - 3)</span>
                        }
                        </div>
                        <button class="member-count">@ev.CurrentParticipants / @ev.MaxParticipants Members</button>
                    </div>
                </div>
            </div>
        }
    </div>
    }
    else if (Model.UserInfo.Settings.ShowHostedEvents && (Model.HostedEvents == null || 
    !Model.HostedEvents.Any()) && (!Model.UserInfo.Settings.PrivateAccount ||
    Model.CurrentLoggedInUserId == Model.UserInfo.Id))
    {
        <div class="private-content-mock">
            <div>📭</div>
            <h3>ยังไม่มีกิจกรรม</h3>
            <p>ผู้ใช้งานยังไม่ได้สร้างกิจกรรมใดๆ</p>
        </div>
    }
    else
    {
        <div class="private-content-mock">
            <div>🔒</div>
            <h3>ข้อมูลส่วนตัว</h3>
            <p>ผู้ใช้งานตั้งค่าซ่อนกิจกรรมที่สร้างไว้</p>
        </div>
    }
</div>

