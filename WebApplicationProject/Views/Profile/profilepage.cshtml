</div>
<div class="rating" id="review-section">
    <h1>Rating</h1>
    @if (Model.UserInfo.Settings.PrivateAccount && Model.CurrentLoggedInUserId != Model.UserInfo.Id)
    {
        <div class="private-content-mock content-mock">
            <div>🔒</div>
            <h2>บัญชีนี้ผู้ใช้ซ่อนรีวิวที่ได้ไว้</h2>
        </div>
    }
    else if (Model.UserInfo.Reviewslist == null || !Model.UserInfo.Reviewslist.Any())
    {
        <div class="private-content-mock content-mock">
            <div>📭</div>
            <h3>ยังไม่ได้รับรีวิวใดๆ</h3>
            <p>ผู้ใช้งานยังไม่ได้รับการรีวิว</p>
        </div>
    }
    else
    {
        <div class="ratinglist">
            @foreach (var rwModel in Model.Reviews)
            {
                var rw = rwModel.ReviewData;
                var author = rwModel.Author;
                var eventTitle = rwModel.EventTitle;
                <div class="reviewblock">
                    <div class="stars">
                        @for (int i = 0; i < rw.stars; i++)
                        {
                            <span>★</span>
                        }
                        @for (int i = rw.stars; i < 5; i++)
                        {
                            <span>☆</span>
                        }
                    </div>
                    <h3>form @eventTitle</h3>
                    <h2>@rw.reviewtitle</h2>
                    <p class="reviewbody">@rw.reviewbody</p>
                    @if (rw.IsAnonymous)
                    {
                        <div class="reviewprofile">
                            <img src="https://ui-avatars.com/api/?name=Anonymous&background=random" alt="Profile">
                            <div class="reviewname">
                                <h4>Anonymous</h4>
                                <p>ผู้รีวิวไม่ระบุชื่อ</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="reviewprofile">
                            <img src=@author.Image alt="Profile">
                            <div class="reviewname">
                                <h4>@author.FName</h4>
                                <p>@author.SName</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }  
</div>

<div id="editProfileModal" class="modal-overlay">
    <div class="modal-content">
        <h1>Edit Profile</h1>
        <div class="exampleprofile">
            @* <div class="profile-rect">
                <img class="preview-img" src="@Model.UserInfo.Image" alt="Rectangle Profile">
            </div> *@
            <div class="profile-circle">
                <img class="preview-img" src="@Model.UserInfo.Image" alt="Circle Profile">
            </div>
        </div>
        <form asp-action="UpdateProfile" asp-controller="Profile" method="post" enctype="multipart/form-data">
            <input type="hidden" name="Id" value="@Model.UserInfo.Id" />
            <div class="modal-body">
                <label>First Name</label>
                <input type="text" name="FName" id="inputFname" value="@Model.UserInfo.FName" class="form-control" />
                <label>Last Name</label>
                <input type="text" name="SName" id="inputSname" value="@Model.UserInfo.SName" class="form-control" />
                <label>Profile Image</label>
            <input type="file" name="uploadImage" id="inputImg" class="form-control" accept="image/*" />
                <label>Email</label>
                <input type="text" name="Email" id="inputEmail" value="@Model.UserInfo.Email" class="form-control" />
                <div class="form-group">
                    <label for="Gender">Gender</label>
                    <select name="Gender" id="inputGender" class="form-control">
                        <option value="">-- เลือกเพศ --</option>
                        <option value="@((int)Genders.Male)" selected="@(Model.UserInfo.Gender == Genders.Male)">Male</option>
                        <option value="@((int)Genders.Female)" selected="@(Model.UserInfo.Gender == Genders.Female)">Female</option>
                        <option value="@((int)Genders.Other)" selected="@(Model.UserInfo.Gender == Genders.Other)">Other</option>
                    </select>
                </div>
                <br>
                
            </div>
            <div class="setting_list">
                <div class="setting">
                    <label class="lable_switch">PrivateAccount</label>
                    <label class="switch">
                        <input type="checkbox" name="IsPublic" value="true" @(Model.UserInfo.Settings.PrivateAccount ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="setting">
                    <label class="lable_switch">ShowEmail</label>
                    <label class="switch">
                        <input type="checkbox" name="ShowEmail" value="true" @(Model.UserInfo.Settings.ShowEmail ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="setting">
                    <label class="lable_switch">ShowJoinedEvents</label>
                    <label class="switch">
                        <input type="checkbox" name="ShowJoinedEvents" value="true" @(Model.UserInfo.Settings.ShowJoinedEvents ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="setting">
                    <label class="lable_switch">ShowHostedEvents</label>
                    <label class="switch">
                        <input type="checkbox" name="ShowHostedEvents" value="true" @(Model.UserInfo.Settings.ShowHostedEvents ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <div> 
                <button class="edit-btn" id="btnRst" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="edit-btn">Save</button>
            </div>
               
        </form>
       
    </div>
</div>
<script src="~/js/app.js"></script>
<script src="~/js/editprofile.js"></script>