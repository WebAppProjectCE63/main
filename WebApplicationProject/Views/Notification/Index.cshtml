@model List<WebApplicationProject.Models.Notification>
<link rel="stylesheet" href="~/css/partiTable.css" />
<link rel="stylesheet" href="~/css/eventPrev_eventForm.css" />
<div class="pagebanner">
    <h1>Notifications</h1>
    <p>การแจ้งเตือนของคุณ</p>
</div>
<div class="my-container">
    <div class="partiTable">
        <div class="tableHeader">
            <h4>รายการแจ้งเตือน</h4>
            <div>
                <button class="view-btn" id="markAllBtn" onclick="markAllRead()">Mark all as read</button>
            </div>
        </div>
        <hr />
        <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>สถานะ</th>
                    <th>หัวข้อ</th>
                    <th>ข้อความ</th>
                    <th>เวลา</th>
                    <th>จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var n in Model)
                {
                    <tr class="notif-row @(n.IsRead ? "read" : "unread")" data-id="@n.Id">
                        <td>@(n.IsRead ? "อ่านแล้ว" : "ใหม่")</td>
                        <td>@n.Title</td>
                        <td>@n.Message</td>
                        <td>@n.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (!n.IsRead)
                            {
                                <button onclick="markRead(@n.Id, this)">Mark read</button>
                            }
                            <a style="margin: 10px" href="@n.Url">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        async function markRead(id, btn){
            try{
                const res = await fetch('/Notification/MarkRead', { method: 'POST', headers: { 'Content-Type':'application/x-www-form-urlencoded' }, body: 'id='+id });
                if(res.ok){
                    const row = btn.closest('tr');
                    if(row){ row.classList.remove('unread'); row.classList.add('read'); row.querySelector('td').innerText='อ่านแล้ว'; btn.remove(); }
                }
            }catch(e){ console.error(e); }
        }
        async function markAllRead(){
            try{
                const res = await fetch('/Notification/MarkAllRead', { method: 'POST' });
                if(res.ok){ document.querySelectorAll('tr.notif-row.unread').forEach(r=>{ r.classList.remove('unread'); r.classList.add('read'); r.querySelector('td').innerText='อ่านแล้ว'; r.querySelector('button')?.remove(); }); }
            }catch(e){ console.error(e); }
        }
    </script>
}
