@using WebApplicationProject.Data
@using WebApplicationProject.Models
@model IEnumerable<WebApplicationProject.Models.Event>
@{
    int currentUserId = Context.Session.GetInt32("UserId") ?? 0;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>My Events</title>
    <link rel="stylesheet" href="~/css/myevent.css">
</head>
<body>
    <div class="pagebanner">
        <h1>My Events</h1>
        <p>กิจกรรมของฉัน</p>
    </div>
    <div class="content-container bg-gray">
        <div class="calendar-wrapper">
            <div class="calendar-card">
                <div class="calendar-header">
                    <button class="nav-btn" id="prevMonth"><i class="fa-solid fa-chevron-left"></i></button>
                    <div class="date-selectors">
                        <select id="monthSelect">
                            <option value="0">Jan</option>
                            <option value="1">Feb</option>
                            <option value="2">Mar</option>
                            <option value="3">Apr</option>
                            <option value="4">May</option>
                            <option value="5">Jun</option>
                            <option value="6">Jul</option>
                            <option value="7">Aug</option>
                            <option value="8">Sep</option>
                            <option value="9">Oct</option>
                            <option value="10">Nov</option>
                            <option value="11">Dec</option>
                        </select>
                        <select id="yearSelect">
                            <option value="2025">2025</option>
                            <option value="2026" selected>2026</option>
                            <option value="2027">2027</option>
                        </select>
                    </div>
                    <button class="nav-btn" id="nextMonth"><i class="fa-solid fa-chevron-right"></i></button>
                </div>

                <div class="calendar-body">
                    <div class="day-names">
                        <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                    </div>
                    <div class="days-grid" id="calendarGrid"></div>
                </div>
            </div>

            <div class="filter-bar">
                <div class="search-input">
                    <input type="text" id="searchInput" placeholder="ค้นหาชื่อกิจกรรม..." style="border:none; outline:none; width:100%; background:transparent; font-family:inherit;">
                </div>

                <div class="search-input">
                    <input type="text" id="searchTagInput" placeholder="ค้นหาตาม Tag (เช่น music)..." style="border:none; outline:none; width:100%; background:transparent; font-family:inherit;">
                    <button id="searchTagBtn" style="background:none; border:none; cursor:pointer; font-weight:bold; color:#333;">ค้นหา</button>
                </div>

                <div class="sort-filter">
                    <span>Sort By</span>
                    <select id="sortSelect" class="pill-select">
                        <option value="date-desc">เวลา (ใหม่ - เก่า)</option>
                        <option value="date-asc">เวลา (เก่า - ใหม่)</option>
                        <option value="members-desc">ผู้เข้าร่วม (มาก - น้อย)</option>
                        <option value="members-asc">ผู้เข้าร่วม (น้อย - มาก)</option>
                        <option value="name-asc">ชื่อ (A - Z)</option>
                        <option value="name-desc">ชื่อ (Z - A)</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="content-container">
        <div class="recommend-section" id="eventContainer">
            <div class="section-title">
                <h2 id="sectionHeader">My Events</h2>
                <p>กิจกรรมที่คุณเป็นโฮสต์และเข้าร่วม</p>
            </div>

            @foreach (var ev in Model)
            {
                var isHost = ev.UserHostId == currentUserId;
                var participantInfo = ev.Participants.FirstOrDefault(p => p.UserId == currentUserId && p.Status != ParticipationStatus.Remove && p.Status != ParticipationStatus.Cancelled);

                if (!isHost && participantInfo == null)
                {
                    continue;
                }
                var maxWaiting = (int)Math.Ceiling(ev.MaxParticipants * 0.5);
                var currentWaiting = ev.Participants.Count(p => p.Status == ParticipationStatus.Waiting);
                <div class="Event" data-date="@ev.DateTime.ToString("yyyy-MM-dd")" data-event-date="@ev.DateTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                    <input type="hidden" name="eventId" value="@ev.Id" />
                    <div class="event-card">
                        <div class="image-column" style="display: flex; flex-direction: column; gap: 8px; align-items: center; flex-shrink: 0;">
                            <div class="event-image">
                                @if (!string.IsNullOrEmpty(ev.Image))
                                {
                                    <img src="@ev.Image" alt="event image" class="event-img-fit" />
                                }
                            </div>

                            @{
                                DateTime now = DateTime.Now;
                                string timeStatusText = "";
                                string statusClass = "";

                                if (now > ev.EndDateTime)
                                {
                                    timeStatusText = "Ended";
                                    statusClass = "status-ended";
                                }
                                else if (now >= ev.DateTime && now <= ev.EndDateTime)
                                {
                                    timeStatusText = "Ongoing";
                                    statusClass = "status-ongoing";
                                }
                                else
                                {
                                    timeStatusText = "Upcoming";
                                    statusClass = "status-upcoming";
                                }
                            }

                            <span class="status-badge @statusClass" style="width: 100%; box-sizing: border-box;">@timeStatusText</span>
                            @if (ev.IsRegistrationClosed)
                            {
                                <span class="status-badge statis-close" style="width: 100%; box-sizing: border-box; background-color: #dc3545; color: white; margin-top: -4px; font-size: 0.85em; padding: 2px;">
                                    🔒 Locked
                                </span>
                            }

                        </div>

                        <div class="event-main">
                            <h3 class="event-title title-flex">
                                @ev.Title
                                @if (isHost)
                                {
                                    <span class="badge badge-host">Host</span>
                                }
                                else if (participantInfo != null)
                                {
                                    bool isWithinOneHour = DateTime.Now >= ev.DateTime.AddMinutes(-1);
                                    bool isClosedWaitlist = (ev.IsRegistrationClosed || isWithinOneHour) && participantInfo.Status == ParticipationStatus.Waiting;
                                    var statusText = participantInfo.Status == ParticipationStatus.Confirmed ? "Joined" :
                                    (isClosedWaitlist ? "Not Selected" : "Waiting");

                                    var badgeClass = participantInfo.Status == ParticipationStatus.Confirmed ? "badge-joined" :
                                    (isClosedWaitlist ? "badge-closed" : "badge-waiting");
                                    <span class="badge @badgeClass">@statusText</span>
                                }
                            </h3>
                            <p class="event-desc">@ev.Description</p>

                            <div class="event-chips">
                                @if (ev.Tags != null && ev.Tags.Any())
                                {
                                    foreach (var tag in ev.Tags)
                                    {
                                        <button type="button" class="chip">@tag</button>
                                    }
                                }
                            </div>
                            <div class="event-row">
                                <span>@ev.Location</span>
                                <span>@ev.DateTime.ToString("dd MMM yyyy")</span>
                            </div>

                            <div class="event-actions normal-actions">
                                <button type="button" class="view-btn view-info-btn">View Info</button>
                                @if (isHost)
                                {
                                    @if (DateTime.Now < ev.DateTime)
                                    {
                                        <a href="@Url.Action("Manage", "Event", new { id = ev.Id })" class="view-btn btn-dark-link">Manage</a>
                                        <a href="@Url.Action("Edit", "Event", new { id = ev.Id })" class="view-btn btn-link">Edit</a>
                                    }
                                }
                            </div>

                            <div class="extra-info">
                                @{
                                    var hostDict = ViewBag.HostDict as Dictionary<int, WebApplicationProject.Models.User>;
                                    var hostUser = (hostDict != null && hostDict.ContainsKey(ev.UserHostId)) ? hostDict[ev.UserHostId] : null;
                                }
                                <p class="info-row host-info-row">
                                    <strong>Host:</strong>
                                    @if (hostUser != null)
                                    {
                                        <a href="@Url.Action("profilepage", "Profile", new { id = ev.UserHostId })" class="host-link">
                                            <img src="@hostUser.Image" alt="Host Image" />
                                            @hostUser.FName @hostUser.SName
                                        </a>
                                    }
                                    else
                                    {
                                        <span>Unknown Host</span>
                                    }
                                </p>

                                <p class="info-row"><strong>Location:</strong> @ev.Location</p>
                                <p class="info-row"><strong>Date:</strong> @ev.DateTime.ToString("dd MMM yyyy HH:mm") - @ev.EndDateTime.ToString("dd MMM yyyy HH:mm")</p>


                                <div class="extra-actions">
                                    @if (isHost)
                                    {
                                        @if (DateTime.Now < ev.DateTime)
                                        {
                                            <a href="@Url.Action("Manage", "Event", new { id = ev.Id })" class="view-btn btn-dark-link">Manage Event</a>
                                            <a href="@Url.Action("Edit", "Event", new { id = ev.Id })" class="view-btn btn-link">Edit</a>
                                        }
                                        else
                                        {
                                            <button type="button" class="view-btn" onclick="window.location.href='@Url.Action("Review", "Review", new { id = ev.Id })'">
                                                View Reviews
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        @if (DateTime.Now >= ev.DateTime)
                                        {
                                            @if (participantInfo?.Status == WebApplicationProject.Models.ParticipationStatus.Confirmed)
                                            {
                                                <button type="button" class="view-btn" onclick="window.location.href='@Url.Action("Review", "Review", new { id = ev.Id })'">
                                                    Review Event
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="view-btn btn-disabled" disabled>
                                                    Event Closed (Not Selected)
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            @if (participantInfo?.Status == WebApplicationProject.Models.ParticipationStatus.Confirmed)
                                            {
                                                <a href="@Url.Action("Participants", "Event", new { id = ev.Id })" class="view-btn">View Participants</a>
                                            }
                                            else
                                            {
                                                <button type="button" class="view-btn btn-disabled realtime-waiting-btn" disabled>
                                                    @(ev.IsRegistrationClosed ? "Event Closed (Not Selected)" : "Waiting for Confirmation")
                                                </button>
                                            }

                                            <form class="realtime-cancel-form" action="@Url.Action("CancelJoin", "Event")" method="post" style="display:@(ev.IsRegistrationClosed ? "none" : "inline-block");"
                                                  onsubmit="return confirm('คุณแน่ใจหรือไม่ว่าต้องการยกเลิกการเข้าร่วมกิจกรรมนี้?');">
                                                <input type="hidden" name="eventId" value="@ev.Id" />
                                                <button type="submit" class="view-btn btn-danger-outline">Cancel Join</button>
                                            </form>
                                        }
                                    }
                                    <button type="button" class="view-btn btn-link close-info-btn">Close</button>
                                </div>
                            </div>
                        </div>

                        <div class="event-stats">
                            <div class="members">@ev.CurrentParticipants/@ev.MaxParticipants Participants</div>
                            <div class="members waiting-box">@currentWaiting/@maxWaiting Reserve</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <script src="~/js/myevent.js"></script>
</body>
</html>