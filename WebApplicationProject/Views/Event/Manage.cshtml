@model WebApplicationProject.Models.Event
<link rel="stylesheet" href="~/css/eventPrev_eventForm.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/partiTable.css" asp-append-version="true" />
<div class="pagebanner">
    <h1>Manage Event</h1>
    <p>จัดการกิจกรรม</p>
</div>
<div class="my-container">
    <h3>Event To Manage</h3>
    <div id="eventPrev" class="eventPrev">
        <div class="eventImage">
            <img id="prevImage" src=@Model.Image />
        </div>
        <div class="eventDetail">
            <h4><b>Title: </b><span id="prevTitle">@Model.Title</span></h4>
            <p><b>Description: </b><span id="prevDesc">@Model.Description</span></p>
            <div>
                <b>Tag(s): </b>
                <span id="prevTags">
                    @if (Model.Tags != null)
                    {
                        foreach (var tag in Model.Tags)
                        {
                            <span class="tag-badge">@tag</span>
                        }
                    }
                </span>
            </div>
            <div class="meta-info">
                <b>Participants: </b>
                <span id="prevMaxParti">
                    @Model.MaxParticipants
                    @if (Model.MaxWaiting > 0)
                    {
                        <text>(@Model.MaxWaiting)</text>
                    }
                </span>
            </div>
            <div class="meta-info">
                <b>Period: </b>
                <span>
                    @if (Model.DateTime.Date == Model.EndDateTime.Date)
                    {
                        <text>@Model.DateTime.ToString("d MMMM yyyy ( HH:mm") - @Model.EndDateTime.ToString("HH:mm )")</text>
                    }
                    else
                    {
                        <text>@Model.DateTime.ToString("d MMMM yyyy ( HH:mm )") - @Model.EndDateTime.ToString("d MMMM yyyy ( HH:mm )")</text>
                    }
                </span>
            </div>
            <div class="meta-info"><b>Regesteration Deadline: </b><span id="prevDeadline">@Model.RegistrationDeadline.ToString("d MMM yyyy ( HH:mm )")</span></div>
            <div class="meta-info"><b>Location: </b><span id="prevLocation">@Model.Location</span></div>
            <a href="@Url.Action("Edit", "Event", new {id = Model.Id})" class="btnLink">Edit</a>
            <button id="toggleRegBtn" type="button"
                    class="btn-toggle @(Model.IsRegistrationClosed ? "btn-toggle-open" : "btn-toggle-close")"
                    onclick="toggleRegistrationStatus(@Model.Id)">
                @(Model.IsRegistrationClosed ? "✅ Open Registeration" : "❌ Close Registeration")
            </button>
        </div>
    </div>
    <div class="mngParti">
        @{
            var userInEvent = ViewBag.ParticipantList as List<WebApplicationProject.Models.User>;
        }
        <div class="partiTable">
            <div class="tableHeader">
                <h4>Participants</h4>
                <div class="numOfParti"><span id="currentParti">@Model.CurrentParticipants</span> / @Model.MaxParticipants Participants</div>
            </div>
            <hr />
            <div class="table-responsive">
                <table>
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Name</th>
                        <th>Rating</th>
                        <th>Join Time</th>
                        <th>Manage</th>
                    </tr>
                </thead>
                <tbody id="confirmedTable">
                    @if (userInEvent != null){
                        int order = 1;
                        @foreach (var ticket in Model.Participants.Where(p => p.Status == ParticipationStatus.Confirmed).OrderBy(p => p.JoinedAt)){
                            var user = userInEvent.FirstOrDefault(u => u.Id == ticket.UserId);
                            if (user != null){

                                    double avgRating = (user.Reviewslist != null && user.Reviewslist.Any())
                                    ? user.Reviewslist.Average(r => r.stars)
                                    : 0.0;

                                <tr id="row_@user.Id">
                                    <td class="seqNumber">@order</td>
                                    <td>
                                        <a href="@Url.Action("profilepage", "Profile", new { id = user.Id })" class="profile-link">
                                            <img src="@user.Image" />@user.FName @user.SName
                                        </a>
                                    </td>
                                    <td class="reviewSC">
                                        @if (avgRating > 0)
                                        {
                                            <span>@avgRating.ToString("0.0")★</span>
                                        }
                                        else
                                        {
                                            <span>ยังไม่มีรีวิว</span>
                                        }
                                    </td>
                                    <td>@ticket.JoinedAt.ToString("dd MMM yyyy HH:mm")</td>
                                    <td><button onclick="removeUser(@Model.Id, @user.Id)">Remove</button></td>
                                </tr>
                                order += 1;
                            }
                        }
                    }
                </tbody>
            </table>
            </div>
        </div>
        @if (Model.MaxWaiting > 0)
        {
            <div class="partiTable">
                <div class="tableHeader">
                    <h4>Reserve</h4>
                    <div class="numOfParti"><span id="currentWait">@Model.CurrentWaiting</span> / @Model.MaxWaiting Reserve</div>
                </div>
                <hr />
                <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Name</th>
                            <th>Rating</th>
                            <th>Join Time</th>
                            <th>Manage</th>
                        </tr>
                    </thead>
                    <tbody id="waitingTable">
                        @if (userInEvent != null)
                        {
                            int order = 1;
                            @foreach (var ticket in Model.Participants.Where(p => p.Status == ParticipationStatus.Waiting).OrderBy(p => p.JoinedAt))
                            {
                                var user = userInEvent.FirstOrDefault(u => u.Id == ticket.UserId);
                                if (user != null){

                                    double avgRating = (user.Reviewslist != null && user.Reviewslist.Any())
                                    ? user.Reviewslist.Average(r => r.stars)
                                    : 0.0;

                                    <tr id="row_@user.Id">
                                        <td class="seqNumber">@order</td>
                                        <td>
                                            <a href="@Url.Action("profilepage", "Profile", new { id = user.Id })" class="profile-link">
                                                <img src="@user.Image" />@user.FName @user.SName
                                            </a>
                                        </td>
                                        <td class="reviewSC">
                                            @if (avgRating > 0)
                                            {
                                                <span>@avgRating.ToString("0.0")★</span>
                                            }
                                            else
                                            {
                                                <span>ยังไม่มีรีวิว</span>
                                            }
                                        </td>
                                        <td>@ticket.JoinedAt.ToString("dd/MM/yy HH:mm")</td>
                                        <td>
                                            <button onclick="promoteUser(@Model.Id, @user.Id)">Add</button>
                                            <button onclick="removeWaitingUser(@Model.Id, @user.Id)">Remove</button>
                                        </td>
                                    </tr>
                                    order += 1;
                                }
                            }
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
    </div>
</div>
<div class="my-container">
    <div class="manage-danger-zone">
        <h3>Delete Event</h3>
        <p>การลบกิจกรรมจะทำให้ข้อมูลทั้งหมดหายไปและไม่สามารถกู้คืนได้</p>

        <form action="@Url.Action("Delete", "Event")" method="post"
              onsubmit="return confirm('แน่ใจหรือไม่ว่าต้องการลบกิจกรรมนี้? ข้อมูลผู้เข้าร่วมและรีวิวทั้งหมดจะถูกลบถาวร!');">
            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn-toggle btn-toggle-close">
                <i class="fa-solid fa-trash-can"></i> Delete
            </button>
        </form>
    </div>
</div>
@section Scripts{
    <script src="~/js/manageEvent.js" ></script>
};